# ===========================================
# LOCAL DEVELOPMENT
# ===========================================
# Start Neo4j: docker-compose -f docker-compose.local.yml up -d
# Run API: uvicorn app.main:app --reload

# Neo4j Connection (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localpassword

# ===========================================
# PRODUCTION (Digital Ocean)
# ===========================================
# Deploy: docker-compose up -d --build
# URL: https://synapse-cortex.juandago.dev
# 
# For production, set these values:
# NEO4J_URI=bolt://neo4j:7687  (container name, set automatically in docker-compose)
# NEO4J_PASSWORD=<strong-password>

# ===========================================
# SHARED CONFIGURATION
# ===========================================

# Google Gemini API — set ONE of these auth modes (preference order matches config.py):
#
# 1. Vertex AI full (REQUIRED for explicit context caching — /v1/chat/completions
#    cost optimization depends on this). Needs a GCP service account with role
#    aiplatform.user and a JSON key. Paste the JSON contents on a single line.
# GCP_PROJECT=your-gcp-project-id
# GCP_LOCATION=global
# GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
#
# 2. Vertex Express (no caching). Simple API key, bills to GCP credits.
# VERTEX_API_KEY=
#
# 3. AI Studio. Simple API key, separate billing. Supports caching but limited quotas.
# GOOGLE_API_KEY=
VERTEX_API_KEY=
GOOGLE_API_KEY=

# API Security
SYNAPSE_API_SECRET=your_api_secret_here

# Graphiti Configuration
# Controls concurrent LLM operations. Lower values help avoid 429 rate limit errors.
# Default is 10. Reduce to 3-5 if you encounter rate limiting issues.
SEMAPHORE_LIMIT=3

# Gemini model for Graphiti knowledge extraction (optional)
# Default: gemini-3-flash-preview
# Options: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
# GRAPHITI_MODEL=gemini-3-flash-preview

AXIOM_API_TOKEN=
AXIOM_DATASET=
AXIOM_DOMAIN=

# PostHog LLM Analytics (optional, disabled if api key is empty)
# Get your project API key from PostHog > Settings > Project API Key
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com